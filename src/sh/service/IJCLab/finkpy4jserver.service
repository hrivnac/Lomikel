[Unit]
Description=Fink Py4J Server
After=network.target

[Service]
Type=simple
User=janusgraph
Group=janusgraph
WorkingDirectory=/localhome/janusgraph/Lomikel/run
ExecStart=/localhome/janusgraph/Lomikel/src/sh/service/IJCLab/finkpy4jserver.sh
KillSignal=SIGTERM
TimeoutStopSec=60
Restart=always
RestartSec=5
SuccessExitStatus=143

[Install]
WantedBy=multi-user.target


